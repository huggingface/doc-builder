{
	"name": "kit",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "rm -Rf src/routes/__pycache__ && vite build && node postprocess && ./postbuild.sh",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check --plugin prettier-plugin-svelte .",
		"format": "prettier --write --plugin prettier-plugin-svelte .",
		"update-inference-providers": "npm ci && npm i @huggingface/inference@latest && npm i @huggingface/tasks@latest"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@huggingface/inference": "^4.13.15",
		"@huggingface/tasks": "^0.20.12",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.27.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/postcss": "^4.1.18",
		"@tailwindcss/typography": "^0.5.19",
		"@types/js-yaml": "^4.0.6",
		"@types/node": "^20.6.5",
		"autoprefixer": "^10.4.24",
		"cheerio": "^1.0.0-rc.12",
		"domutils": "^2.8.0",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^16.5.0",
		"highlight.js": "^11.8.0",
		"html-tags": "^3.3.1",
		"htmlparser2": "^7.2.0",
		"js-yaml": "^4.1.0",
		"katex": "^0.16.22",
		"mdsvex": "^0.12.6",
		"mermaid": "^11.12.0",
		"postcss": "^8.5.6",
		"postcss-load-config": "^6.0.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"tslib": "^2.4.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.4",
		"unist-util-visit": "^5.0.0",
		"vite": "^7.3.4"
	},
	"type": "module"
}
